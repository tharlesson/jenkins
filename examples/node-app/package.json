{
  "name": "node-app",
  "version": "1.0.0",
  "description": "Minimal Node sample for Jenkins CI validation",
  "main": "src/index.js",
  "scripts": {
    "lint": "node --check src/index.js src/sum.js",
    "test": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "coverage": "jest --coverage",
    "build": "mkdir -p dist && cp -r src/* dist/"
  },
  "jest-junit": {
    "outputDirectory": "test-results",
    "outputName": "junit.xml"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0"
  }
}
